<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - presentacion_aspnetcore</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/presentacion_aspnetcore.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: var(--bg-dark-card);">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Gestion de Eventos uwu</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-area=""
                               asp-page="/Index">
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-area=""
                               asp-page="/Privacy">
                                Privacy
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Administrador"))
            {
                    <a class="nav-link rounded-pill px-4"
                       asp-area=""
                       asp-page="/Ventanas/Admin">
                        Admin
                    </a>  
            }

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="dropdown">
                    <button class="nav-link rounded-pill dropdown-toggle px-3" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                            @User.Identity.Name
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-secondary bg-dark" aria-labelledby="userMenu">
                        <li>
                            <form method="post" asp-page="/Ventanas/Login" asp-page-handler="BtCerrarSesion" class="px-2">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger rounded btn-sm fw-semibold">
                                    Cerrar Sesión
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {    
                <a asp-page="/Ventanas/Login" class="nav-link rounded-pill px-4">
                    Iniciar Sesión
                </a>
            }
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>
    <footer class="footer text-muted">
        <div class="container">
            &copy; 2026 - Naturaleza - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>