@page
@model TransportesModel
@{
    ViewData["Title"] = "Transportes";
}
<center>
    <div>
        <form method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Transportes</h3>
            </div>

            <div>
                <input type="submit" value="Nuevo" class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Transporte != null)" />
                <input type="submit" value="Refrescar" class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit" value="Guardar" class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Transporte == null)" />
            </div>

            @if (Model.Transporte != null)
            {
                <div>
                    <div class="form-group">
                        <label>Id</label>
                        <div class="col-6">
                            <input id="inId" class="cts_forms form-control" asp-for="@Model.Transporte!.Id" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Vehiculo</label>
                        <div class="col-6">
                            <input id="inVehiculo" class="form-control" asp-for="@Model.Transporte!.Vehiculo" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Placa</label>
                        <div class="col-6">
                            <input id="inPlaca" class="form-control" asp-for="@Model.Transporte!.Placa" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Capacidad</label>
                        <div class="col-6">
                            <input id="inCapacidad" class="cts_forms form-control" asp-for="@Model.Transporte!.Capacidad" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Estado</label>
                        <div class="col-6">
                            <input id="inEstado" asp-for="@Model.Transporte!.Estado" />
                        </div>
                    </div>
                </div>
            }

            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
            }

            @if (Model.Transporte != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="Left">Desea borrar el Transporte?</h6>
                            <h6 align="Left">@Model.Transporte!.Vehiculo</h6>
                            <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                            <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>Id</th>
                        <th>Vehiculo</th>
                        <th>Placa</th>
                        <th>Capacidad</th>
                        <th>Estado</th>
                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <th>@elemento.Id</th>
                            <th>@elemento.Vehiculo</th>
                            <th>@elemento.Placa</th>
                            <th>@elemento.Capacidad</th>
                            <th>@elemento.Estado</th>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar"
                                       class="btn btn-secondary" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>
