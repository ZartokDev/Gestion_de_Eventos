@page
@model TransportesModel

@{
    ViewData["Title"] = "Gestión de Transportes";
}

<div class="container-fluid py-4">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="text-white fw-bold mb-0">🚗 Panel de Gestión de Transportes</h2>
                <p class="text-white-50 small">Administra los registros de transportes del sistema.</p>
            </div>
            <div class="btn-group gap-2 shadow-sm">
                <button type="submit" asp-page-handler="BtNuevo" class="btn btn-primary px-4 rounded-pill"
                        disabled="@(Model.Transporte != null)">
                    ➕ Nuevo
                </button>
                <button type="submit" asp-page-handler="BtRefrescar" class="btn btn-outline-light px-3 rounded-pill">
                    🔄 Sincronizar
                </button>
            </div>
        </div>

        @if (Model.Transporte != null)
        {
            <div class="card card-crud mb-5">
                <div class="card-header py-3 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-primary fw-bold">
                        @(Model.Transporte.Id == 0 ? "✨ Registrar Nuevo Transporte" : "📝 Modificar Transporte ID: " + Model.Transporte.Id)
                    </h5>
                    <button type="submit" asp-page-handler="BtGuardar" class="btn btn-success px-4 rounded-pill">
                        💾 Guardar Cambios
                    </button>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <input type="hidden" asp-for="@Model.Transporte!.Id" />

                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Vehiculo</label>
                            <input class="form-control" asp-for="@Model.Transporte!.Vehiculo" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Placa</label>
                            <input class="form-control" asp-for="@Model.Transporte!.Placa" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Capacidad</label>
                            <input type="number" class="form-control" placeholder="0" asp-for="@Model.Transporte!.Capacidad" />
                        </div>
                        <div class="col-md-4 d-flex align-items-center mt-2">
                            <div class="form-check form-switch ps-5">
                                <input class="form-check-input scale-125" type="checkbox" asp-for="@Model.Transporte!.Estado" />
                                <label class="form-check-label fw-semibold text-muted ms-2">Estado Activo</label>
                            </div>
                        </div>
                        <div class="col-12 mt-4">
                            <h6 class="text-uppercase text-muted small border-bottom pb-2">Relaciones</h6>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Tipo de Transporte</label>
                            @if (Model.ListaTipoTransportes != null)
                            {
                                <select class="form-select" asp-for="@Model.Transporte!.TipoTransporte"
                                        asp-items="@(new SelectList(Model.ListaTipoTransportes, "Id", "Nombre"))">
                                    <option value="">-- Seleccione un Tipo --</option>
                                </select>
                            }
                        </div>

                    </div>
                </div>
            </div>
        }

        @if (Model.Lista != null && Model.Lista.Count > 0)
        {
            <div class="card card-crud">
                <div class="card-header py-3">
                    <h5 class="mb-0 text-white fw-bold">📋 Registro de Transportes</h5>
                </div>
                <div class="table-responsive table-responsive-custom">
                    <table class="tb_data mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Vehiculo</th>
                                <th>Placa</th>
                                <th>Capacidad</th>
                                <th>Estado</th>
                                <th>Tipo Transporte</th>
                                <th class="text-center">Operaciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var elemento in Model.Lista)
                            {
                                <tr>
                                    <td><strong>#@elemento.Id</strong></td>
                                    <td>@elemento.Vehiculo</td>
                                    <td>@elemento.Placa</td>
                                    <td>@elemento.Capacidad</td>
                                    <td>@if (elemento.Estado)
                                {
                                    <span class="badge bg-success-subtle text-success px-3 py-1 rounded-pill">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger px-3 py-1 rounded-pill">Inactivo</span>
                                }</td>
                                    <td>@elemento.TipoTransporte</td>

                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm shadow-sm" role="group">
                                            <button type="submit" asp-page-handler="BtModificar"
                                                    asp-route-data="@elemento.Id"
                                                    class="btn btn-warning text-dark fw-semibold">
                                                ✏️ Editar
                                            </button>
                                            <button type="submit" asp-page-handler="BtBorrarVal"
                                                    asp-route-data="@elemento.Id"
                                                    class="btn btn-danger">
                                                🗑️ Borrar
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
        }

        @if (Model.Transporte != null && Model.Borrando)
        {
            <div class="popup">
                <div class="pp_inner text-center">
                    <div class="text-danger mb-3" style="font-size: 3rem;">⚠️</div>
                    <h4 class="fw-bold text-white mb-2">¿Confirmar Eliminación?</h4>
                    <p class="text-muted mb-4">Está a punto de borrar permanentemente: <br>
                        <strong class="text-white">"@Model.Transporte!.Vehiculo"</strong>
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <button type="submit" asp-page-handler="BtCerrar"
                                class="btn btn-outline-light px-4 rounded-pill">Cancelar</button>
                        <button type="submit" asp-page-handler="BtBorrar"
                                class="btn btn-danger px-4 rounded-pill">Sí, Eliminar</button>
                    </div>
                </div>
            </div>
        }

    </form>
</div>
