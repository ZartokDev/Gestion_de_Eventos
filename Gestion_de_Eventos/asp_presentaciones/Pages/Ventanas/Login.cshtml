@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="card card-crud p-4" style="width: 100%; max-width: 400px;">
        <h3 class="text-white fw-bold text-center mb-4">🔐 Ingresar al Sistema</h3>

        <form method="POST">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center fw-bold"></div>

            <div class="mb-3">
                <label class="form-label">Correo Electrónico</label>
                <input type="email" id="inCorreo" asp-for="Correo" class="form-control" placeholder="usuario@correo.com" required />
            </div>

            <div class="mb-4">
                <label class="form-label">Contraseña</label>
                <input type="password" id="inContrasena" asp-for="Contraseña" class="form-control" placeholder="••••••••" required />
            </div>

            <button type="submit" asp-page-handler="BtIngresar" id="btnIngresar" class="btn btn-primary w-100 rounded-pill" disabled>
                Ingresar
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const correo = document.getElementById('inCorreo');
        // El ID generado automáticamente por asp-for="Contraseña" será 'inContrasena' o 'Contraseña'
        // Para asegurar que JavaScript lo encuentre, usamos el id manual que le dejamos
        const contrasena = document.getElementById('inContrasena');
        const btn = document.getElementById('btnIngresar');

        function validarCampos() {
            btn.disabled = correo.value.trim() === '' || contrasena.value.trim() === '';
        }

        correo.addEventListener('input', validarCampos);
        contrasena.addEventListener('input', validarCampos);
    </script>
}