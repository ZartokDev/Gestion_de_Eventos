@page "{id:int}"
@model RegistrarPagoModel
@{
    ViewData["Title"] = "Procesar Factura";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card card-crud p-4 w-100" style="max-width: 650px;">

        <div class="text-center mb-4">
            <h3 class="text-white fw-bold">Procesamiento de Factura</h3>
            <p class="text-white-50 small">Vincule los parámetros de pago y descuentos para el evento registrado.</p>
        </div>

        <form method="POST">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="IdEvento" />
            <input type="hidden" asp-for="Factura!.Id" />
            <input type="hidden" asp-for="Factura!.FechaEmision" />

            @if (Model.EventoActual != null)
            {
                <div class="p-3 mb-4 rounded-3 border border-secondary bg-dark-main px-4 small">
                    <div class="row g-1 text-start">
                        <div class="col-sm-4 text-white-50">Evento Asociado:</div>
                        <div class="col-sm-8 text-white fw-bold">@Model.EventoActual.Nombre</div>
                        <div class="col-sm-4 text-white-50">Asistentes:</div>
                        <div class="col-sm-8 text-white">@Model.EventoActual.CantPersonas personas</div>
                    </div>
                </div>
            }

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Número de Factura</label>
                    <input class="form-control" asp-for="Factura!.NumFactura" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Estado Actual</label>
                    <input class="form-control text-warning fw-bold"
                           value="@(Model.Factura!.EstadoPago ? "Pagado" : "Pendiente")" readonly />
                    <input type="hidden" asp-for="Factura!.EstadoPago" />
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Método de Pago</label>
                    @if (Model.ListaTipoPagos != null)
                    {
                        <select class="form-select"
                                asp-for="IdTipoPago"
                                asp-items="@(new SelectList(Model.ListaTipoPagos, "Id", "Nombre"))" required>
                            <option value="">-- Seleccione un Pago --</option>
                        </select>
                    }
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Aplicar Oferta</label>
                    @if (Model.ListaOfertas != null)
                    {
                        <select class="form-select"
                                asp-for="IdOferta"
                                asp-items="@(new SelectList(Model.ListaOfertas, "Id", "Nombre"))"
                                onchange="this.form.action='?handler=BtAplicarOferta'; this.form.submit();">
                            <option value="0">-- Sin Oferta aplicable --</option>
                        </select>
                    }
                </div>

                @if (ViewData["InfoMensaje"] != null)
                {
                    <div class="col-12 mt-2">
                        <div class="alert alert-success py-1 px-3 small text-center mb-0" role="alert">
                            @ViewData["InfoMensaje"]
                        </div>
                    </div>
                }
            </div>

            <div class="mb-4 p-3 rounded-3 bg-dark-main border border-secondary text-center">
                <label class="form-label text-white-50 small d-block mb-1">Monto Total Liquidado</label>
                <div class="d-flex justify-content-center align-items-center gap-1">
                    <span class="text-primary fs-3 fw-bold">$</span>
                    <input class="form-control bg-transparent border-0 text-primary fs-3 fw-bold text-center w-50 p-0"
                           asp-for="Factura!.Total" readonly />
                </div>
            </div>

            <div class="d-flex gap-3">
                <a asp-page="Index" class="btn btn-outline-secondary w-50 rounded-pill fw-bold">
                    Pagar Después
                </a>
                <button type="submit" asp-page-handler="BtGuardar" class="btn btn-success w-50 rounded-pill fw-bold">
                    Liquidar Factura
                </button>
            </div>
        </form>
    </div>
</div>

@if (ViewData.ContainsKey("Mensaje"))
{
    @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
}