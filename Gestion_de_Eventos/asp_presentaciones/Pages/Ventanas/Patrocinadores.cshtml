@page
@model PatrocinadoresModel
@{
    ViewData["Title"] = "Patrocinadores";
}
<center>
    <div>
        <form method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Patrocinadores</h3>
            </div>

            <div>
                <input type="submit" value="Nuevo" class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Patrocinador != null)" />
                <input type="submit" value="Refrescar" class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit" value="Guardar" class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Patrocinador == null)" />
            </div>

            @if (Model.Patrocinador != null)
            {
                <div>
                    <div class="form-group">
                        <label>Id</label>
                        <div class="col-6">
                            <input id="inId" class="cts_forms form-control" asp-for="@Model.Patrocinador!.Id" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Nombre</label>
                        <div class="col-6">
                            <input id="inNombre" class="form-control" asp-for="@Model.Patrocinador!.Nombre" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Correo</label>
                        <div class="col-6">
                            <input id="inCorreo" class="form-control" asp-for="@Model.Patrocinador!.Correo" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Telefono</label>
                        <div class="col-6">
                            <input id="inTelefono" class="form-control" asp-for="@Model.Patrocinador!.Telefono" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Direccion</label>
                        <div class="col-6">
                            <input id="inDireccion" class="form-control" asp-for="@Model.Patrocinador!.Direccion" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>TipoPatrocinador</label>
                        <div class="col-6">
                            <input id="inTipoPatrocinador" asp-for="@Model.Patrocinador!.TipoPatrocinador" />
                        </div>
                    </div>
                </div>
            }

            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
            }

            @if (Model.Patrocinador != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="Left">Desea borrar el Patrocinador?</h6>
                            <h6 align="Left">@Model.Patrocinador!.Nombre</h6>
                            <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                            <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>Id</th>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Telefono</th>
                        <th>Direccion</th>
                        <th>TipoPatrocinador</th>
                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <th>@elemento.Id</th>
                            <th>@elemento.Nombre</th>
                            <th>@elemento.Correo</th>
                            <th>@elemento.Telefono</th>
                            <th>@elemento.Direccion</th>
                            <th>@elemento.TipoPatrocinador</th>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar"
                                       class="btn btn-secondary" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>
