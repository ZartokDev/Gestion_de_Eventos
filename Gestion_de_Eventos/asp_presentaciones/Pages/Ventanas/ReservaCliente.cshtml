@page
@model ReservaClienteModel
@{
    ViewData["Title"] = "Verificar Cliente";
}

<div class="container d-flex flex-column justify-content-center align-items-center" style="min-height: 75vh;">

    <div class="card card-crud p-4 w-100" style="max-width: 600px;">

        <div class="text-center mb-4">
            <h3 class="text-white fw-bold">Verificación de Cliente</h3>
            <p class="text-white-50 small">Valide los datos del perfil antes de proceder con el formulario del evento.</p>
        </div>

        @if (ViewData["Mensaje"] != null)
        {
            <div class="alert alert-danger text-center small py-2 mb-3" role="alert">
                @ViewData["Mensaje"]
            </div>
        }

        <form method="POST" class="mb-4">
            @Html.AntiForgeryToken()

            <div class="mb-2">
                <label class="form-label">Número de Documento (C.C. / NIT)</label>
                <div class="input-group">
                    <input type="text" id="inDocumento" asp-for="DocumentoBusqueda" class="form-control" placeholder="Ej. 123456789" required readonly="@Model.BusquedaRealizada" />

                    @if (!Model.BusquedaRealizada)
                    {
                        <button type="submit" asp-page-handler="Buscar" id="btnBuscar" class="btn btn-electric px-4 fw-bold text-nowrap" disabled>
                            Buscar
                        </button>
                    }
                    else
                    {
                        <button type="submit" asp-page-handler="Limpiar" class="btn btn-outline-secondary px-4 fw-bold text-nowrap">
                            Nueva búsqueda
                        </button>
                    }
                </div>
            </div>
        </form>

        @if (Model.BusquedaRealizada && Model.ClienteEncontrado != null)
        {
            <div class="p-4 mb-4 rounded-3 border border-secondary bg-dark-main animate__animated animate__fadeIn">
                <h5 class="text-electric fw-bold mb-3 tracking-wider uppercase text-start fs-6 text-center">Perfil de Cliente Detectado</h5>

                <div class="row g-2 text-start px-2">
                    <div class="col-sm-4 text-white-50 small">Nombre / Razón Social:</div>
                    <div class="col-sm-8 text-white fw-bold mb-1">@Model.ClienteEncontrado.Nombre</div>

                    <div class="col-sm-4 text-white-50 small">Documento:</div>
                    <div class="col-sm-8 text-white mb-1">@Model.ClienteEncontrado.Documento</div>

                    <div class="col-sm-4 text-white-50 small">Teléfono de contacto:</div>
                    <div class="col-sm-8 text-white mb-1">@Model.ClienteEncontrado.Telefono</div>

                    <div class="col-sm-4 text-white-50 small">Correo Electrónico:</div>
                    <div class="col-sm-8 text-white">@Model.ClienteEncontrado.Correo</div>
                </div>
            </div>

            <form method="POST">
                @Html.AntiForgeryToken()
                <input type="hidden" name="idCliente" value="@Model.ClienteEncontrado.Id" />

                <div class="d-flex gap-3">
                    <a asp-page="/ReservaInicio" class="btn btn-outline-secondary w-50 rounded-pill fw-bold transform-hover">
                        Regresar
                    </a>
                    <button type="submit" asp-page-handler="Continuar" class="btn btn-electric w-50 rounded-pill fw-bold transform-hover">
                        Proceder al Evento
                    </button>
                </div>
            </form>
        }
        else if (!Model.BusquedaRealizada)
        {
            <div class="d-flex justify-content-start mt-2">
                <a asp-page="/ReservaInicio" class="btn btn-outline-secondary rounded-pill fw-bold px-4 transform-hover">
                    Regresar
                </a>
            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        const documento = document.getElementById('inDocumento');
        const btnBuscar = document.getElementById('btnBuscar');

        if (btnBuscar) {
            function validarBuscador() {
                btnBuscar.disabled = documento.value.trim() === '';
            }
            documento.addEventListener('input', validarBuscador);
        }
    </script>
}